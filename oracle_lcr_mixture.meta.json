{
  "input": "lcr_mixture.final.csv",
  "output": "oracle_lcr_mixture.csv",
  "rows": 500,
  "text_column": "Prompt",
  "carry_columns": [
    "Category",
    "Subject",
    "Context Dependency",
    "SourceDataset",
    "SourceSplit",
    "SourceId"
  ],
  "backbone_model": "TinyLlama/TinyLlama-1.1B-Chat-v1.0",
  "sparse_target": "attention_heads",
  "sparse_intensity": 0.5,
  "max_length": 256,
  "normalization": {
    "method": "pclip_minmax",
    "p_low": 5.0,
    "p_high": 95.0,
    "clip_low": 16.858880833975828,
    "clip_high": 162.41284114882302
  }
}